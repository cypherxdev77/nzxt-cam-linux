{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NZXT CAM Linux",
  "version": "1.0.0",
  "identifier": "io.nzxtcam.archlinux-rust",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NZXT CAM Linux",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#0e0e0e",
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$APPDATA/**", "$RESOURCE/**"]
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "NZXT Kraken Elite LCD controller for Arch Linux",
    "longDescription": "Native Rust + Tauri application to control the LCD screen of NZXT Kraken Elite AIO coolers on Linux. Replaces the Windows-only NZXT CAM software.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": ["resources/*"],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
